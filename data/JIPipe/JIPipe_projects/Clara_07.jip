      "7a176584-e163-46d8-a153-e9832c1608dc/jipipe:adaptive-parameters/overridden-parameters" : {
        "important" : true,
        "name" : "Overridden parameters",
        "description" : "Here you can override the value of parameters based on annotations. The 'Value' settings should return a value for the parameter type or a JSON string that can be converted into a valid parameter value. The 'Parameter key' setting determines to which parameter this value is written to."
      },
      "8bb66c7f-a094-410e-97f7-35401b4459f4/operation" : {
        "name" : "Operation",
        "description" : "The morphological operation. Following operations are supported: <ul><li><b>Erosion: </b>A local minimum filter</li><li><b>Dilation: </b>A local maximum filter</li><li><b>Opening: </b>Erosion, followed by dilation</li><li><b>Closing: </b>Dilation, followed by erosion</li><li><b>White Top Hat: </b>Image - Opening</li><li><b>Black Top Hat (Black Hat): </b>Closing - Image</li><li><b>Gradient: </b>Dilation - Erosion</li><li><b>Laplacian: </b>(Dilation + Erosion) / 2 - Image</li><li><b>Internal gradient: </b>Image - Erosion</li><li><b>External gradient: </b>Dilation - Image</li></ul>"
      },
      "2817e4fd-eafb-456f-9190-1876208d4b4c/composite-roi" : {
        "name" : "Composite ROI",
        "description" : "If enabled, generate composite ROI that can contain holes. Please note that not all operations can appropriately handle composite ROI."
      },
      "f5a80756-63aa-4131-9993-57bc05b664e4/jipipe:adaptive-parameters/attach-parameter-annotations" : {
