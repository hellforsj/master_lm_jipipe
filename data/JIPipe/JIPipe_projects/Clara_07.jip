                  "expression" : "row"
                },
                "short-key" : "value",
                "ui-order" : 0,
                "field-class-id" : "expression"
              }
            }
          },
          "items" : [ {
            "parameters" : {
              "column-name" : {
                "key" : "column-name",
                "name" : "Column name",
                "description" : "The name of the column where the value will be written",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "\"Uptake Ratio\""
                },
                "short-key" : "column-name",
                "ui-order" : 0,
                "field-class-id" : "expression"
              },
              "value" : {
                "key" : "value",
                "name" : "Value",
                "description" : "The generated value",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "TO_NUMBER($\"Phagocytosing macrophages\") / TO_NUMBER($\"All macrophages\")"
                },
                "short-key" : "value",
                "ui-order" : 0,
                "field-class-id" : "expression"
              }
            }
          }, {
            "parameters" : {
              "column-name" : {
                "key" : "column-name",
                "name" : "Column name",
                "description" : "The name of the column where the value will be written",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "\"Phagocytosis Ratio\""
                },
                "short-key" : "column-name",
                "ui-order" : 0,
                "field-class-id" : "expression"
              },
              "value" : {
                "key" : "value",
                "name" : "Value",
                "description" : "The generated value",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "MAX(TO_NUMBER($\"Phagocytosed spores\"), 1.0) / MAX(TO_NUMBER($\"Associated spores\"), 1.0)"
                },
                "short-key" : "value",
                "ui-order" : 0,
                "field-class-id" : "expression"
              }
            }
          }, {
            "parameters" : {
              "column-name" : {
                "key" : "column-name",
                "name" : "Column name",
                "description" : "The name of the column where the value will be written",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "\"Symmetrized Phagocytic Index\""
                },
                "short-key" : "column-name",
                "ui-order" : 0,
                "field-class-id" : "expression"
              },
              "value" : {
                "key" : "value",
                "name" : "Value",
                "description" : "The generated value",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "MAX(TO_NUMBER($\"Phagocytosed spores\"), 1.0) / MAX(TO_NUMBER($\"Associated spores\"), 1.0)  *  TO_NUMBER($\"Phagocytosing macrophages\") / TO_NUMBER($\"All macrophages\")"
                },
                "short-key" : "value",
                "ui-order" : 0,
                "field-class-id" : "expression"
              }
            }
          }, {
            "parameters" : {
              "column-name" : {
                "key" : "column-name",
                "name" : "Column name",
                "description" : "The name of the column where the value will be written",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "\"Phagocytic Index\""
                },
                "short-key" : "column-name",
                "ui-order" : 0,
                "field-class-id" : "expression"
              },
              "value" : {
                "key" : "value",
                "name" : "Value",
                "description" : "The generated value",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "MAX(TO_NUMBER($\"Phagocytosed spores\"), 1.0) / MAX(TO_NUMBER($\"Phagocytosing macrophages\"), 1.0)  *  MAX(TO_NUMBER($\"Phagocytosing macrophages\"), 1.0) / MAX(TO_NUMBER($\"All macrophages\"), 1.0)"
                },
                "short-key" : "value",
                "ui-order" : 0,
                "field-class-id" : "expression"
              }
            }
          }, {
            "parameters" : {
              "column-name" : {
                "key" : "column-name",
                "name" : "Column name",
                "description" : "The name of the column where the value will be written",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "\"All spores\""
                },
                "short-key" : "column-name",
                "ui-order" : 0,
                "field-class-id" : "expression"
              },
              "value" : {
                "key" : "value",
                "name" : "Value",
                "description" : "The generated value",
                "hidden" : false,
                "field-class" : "org.hkijena.jipipe.plugins.expressions.JIPipeExpressionParameter",
                "value" : {
                  "expression" : "TO_NUMBER($\"Associated spores\")  + TO_NUMBER($\"All free spores\") "
                },
                "short-key" : "value",
                "ui-order" : 0,
                "field-class-id" : "expression"
              }
            }
          } ]
