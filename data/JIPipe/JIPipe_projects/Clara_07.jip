      },
      "9ba4c0ca-c0cc-4668-b466-871c57a5e4ee/duplicate-image" : {
        "name" : "Duplicate image",
        "description" : "As the LUT modification does not change any image data, you can disable creating a duplicate."
      },
      "68997ba1-f4a5-445c-b7c2-8e01a22cdafa/jipipe:data-batch-generation/custom-matched-columns-expression" : {
        "pinned" : true,
        "name" : "Custom grouping columns",
        "description" : "Only used if 'Grouping method' is set to 'Custom'. Determines which annotation columns are referred to group data sets. \n\nThis parameter is an expression that has two modes: (1) Selecting an existing string, and (2) Matching an existing strings by boolean operators<br/><ol><li>Type in the string in double quotes. Example: <pre>\"hello world\"</pre></li><li>The function iterates through all strings. It should return TRUE for one of them. You will have a variable 'value' available within the expression. Example: <pre>value CONTAINS \"hello\"</pre></li></ol>"
      },
      "66090fc8-6bd2-4de7-9f99-ddf0c2cfc17a/jipipe:algorithm:enabled" : {
        "pinned" : true,
        "name" : "Enabled",
        "description" : "If disabled, this algorithm will be skipped in a run. Please note that this will also disable all algorithms dependent on this algorithm."
      },
      "1472d59b-ad85-4499-8960-3bd125c2bb9b/deduplicate" : {
        "name" : "Deduplicate",
        "description" : "If enabled, duplicate values for names, locations, etc are removed."
      },
      "980ce2eb-df41-43ed-9f8a-0d75b6fac90f/jipipe:algorithm:enabled" : {
        "pinned" : true,
        "name" : "Enabled",
        "description" : "If disabled, this algorithm will be skipped in a run. Please note that this will also disable all algorithms dependent on this algorithm."
      },
      "b70c26d0-01e8-499c-acc5-7be241dffed5/jipipe:adaptive-parameters/overridden-parameters" : {
        "important" : true,
        "name" : "Overridden parameters",
        "description" : "Here you can override the value of parameters based on annotations. The 'Value' settings should return a value for the parameter type or a JSON string that can be converted into a valid parameter value. The 'Parameter key' setting determines to which parameter this value is written to."
      },
      "56d2d2b2-c091-4b1f-9259-5f545949196d/enable-3d-segmentation" : {
        "important" : true,
        "name" : "Enable 3D segmentation",
        "description" : "If enabled, Cellpose will segment in 3D. Otherwise, any 3D image will be processed per-slice. Please note that 3D segmentation requires large amounts of memory."
      },
      "3248de76-1b33-46ed-b7be-9dceae2a1829/jipipe:node:description" : {
        "pinned" : true,
        "name" : "Description",
        "description" : "A custom description"
      },
      "58ab36da-0797-49d1-82ce-948eb0f49ef2/jipipe:parameter-slot-algorithm/has-parameter-slot" : {
        "name" : "Multiple parameters",
        "description" : "If enabled, there will be an additional slot that consumes parameter data sets. The algorithm then will be applied for each of this parameter sets."
      },
      "2c671024-8450-4049-be53-282234c7150c/jipipe:adaptive-parameters/enabled" : {
        "name" : "Enable adaptive parameters",
        "description" : "If enabled, you can use custom expressions to generate parameters. Please note that this will disable parallelization."
      },
      "1e029140-9dac-48f6-95a6-5cfac3feee55/add-border" : {
        "name" : "Add border before applying operation",
        "description" : "If enabled, a custom border is created around the image and removed afterwards. Otherwise, MorphoLibJ will assume a default outside value determined by ImageJ."
      },
      "627cdd9c-e353-4a61-af30-2380feaed771/jipipe:data-batch-generation/data-annotation-merge-strategy" : {
        "name" : "Merge same data annotation values",
        "description" : "Determines which strategy is applied if different values for the same data annotation columns are encountered."
      },
      "17ff7609-3b16-4d76-bfa3-f8257509619e/roi1/overlap-filter" : {
        "name" : "Overlap filter",
        "description" : "This filter is applied to any combination of ROIs that have an overlap. You will have three sets of measurements: ROI1, Overlap, and ROI2.'ROI1'and 'ROI2' correspond to a ROI from the input slots,respectively. 'Overlap' is the overlap between these ROI. Please open the expression builder to see a list of all available variables. If the filter is empty, no filtering is applied."
      },
      "1d6e253e-8e09-4964-992c-cbde16208766/image-type-annotation" : {
        "name" : "Annotate with image type",
        "description" : "If enabled, an annotation with provided name is created. The annotation contains one of the following values: GRAY8, GRAY16, GRAY32, COLOR_256, COLOR_RGB, or UNKNOWN"
      },
      "a3f69a70-df7a-4eda-9d33-43ee96e3dad1/annotation-type" : {
        "name" : "Split slices annotation",
        "description" : "The annotation type generated by 'Split slices'. You can select no annotation type to disable this feature."
      },
      "d138d5f3-e448-4c24-9af9-03f784d525aa/target-slots/Z stack" : {
        "name" : "Z stack"
      },
      "7071038a-2d03-4ec0-923b-5546a7fb12ba/jipipe:node:ui-locked" : {
        "pinned" : true,
        "hidden" : true,
        "name" : "Lock location/size",
        "description" : "If enabled, lock the location and size of this node. Does not affect automated alignment operations. Will lock the size if the node supports a resize handle. Will prevent deletion of the node by the user. Slots can still be edited/connected and parameters can still be changed."
      },
      "35510e28-b127-428c-86f8-81c1bae0a4eb/jipipe:adaptive-parameters/enabled" : {
        "name" : "Enable adaptive parameters",
        "description" : "If enabled, you can use custom expressions to generate parameters. Please note that this will disable parallelization."
      },
      "168b7e93-76a5-43f6-933a-d6d5a6c2e78f/cleanup-afterwards" : {
        "name" : "Clean up data after processing",
        "description" : "If enabled, data is deleted from temporary directories after the processing was finished. Disable this to make it possible to debug your scripts. The directories are accessible via the logs (Tools &gt; Logs)."
      },
      "cd5f30ac-21e4-47a7-a620-3cbbfc922dbe/border-parameters/jipipe:parameter-slot-algorithm/attach-only-non-default-parameter-annotations" : {
