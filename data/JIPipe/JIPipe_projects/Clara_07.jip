      "b595c4e1-36f4-4fc2-9615-83a5050ff091/jipipe:data-batch-generation/force-na-is-any" : {
        "name" : "Force NA is ANY (if available)",
        "description" : "If enabled, missing annotations are considered as ANY (and thus merged with other data) even if there is only one input. Currently only works for the dictionary solver."
