        "description" : "If enabled, there will be an additional slot that consumes parameter data sets. The algorithm then will be applied for each of this parameter sets."
      },
      "d816dc3c-1ec2-4a01-8a75-68d840698732/fill-outline" : {
        "name" : "Draw filled outline",
        "description" : "If enabled, fill the ROI areas"
      },
      "2d684f17-b094-438d-8496-0c95cf44843a/roi1/fast-mode" : {
        "name" : "Fast mode",
        "description" : "If enabled, only the bounding box is used to calculate overlaps. This includes overlaps generated with 'Output overlapping regions'. This is faster than the logical AND operation applied by default, but will lead to problems if the ROI are close to each other or very non-box-like."
      },
      "df07ba4f-293f-46ae-bc7a-9092ebc524e8/jipipe:parameter-slot-algorithm/parameter-annotations-prefix" : {
