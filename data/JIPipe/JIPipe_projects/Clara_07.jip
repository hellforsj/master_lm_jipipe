      "b8ab9174-3d54-45b4-befc-64f1bb27bd12/jipipe:node:description" : {
        "pinned" : true,
        "name" : "Description",
        "description" : "A custom description"
      },
      "17ff7609-3b16-4d76-bfa3-f8257509619e/roi1/fast-mode" : {
        "name" : "Fast mode",
        "description" : "If enabled, only the bounding box is used to calculate overlaps. This includes overlaps generated with 'Output overlapping regions'. This is faster than the logical AND operation applied by default, but will lead to problems if the ROI are close to each other or very non-box-like."
      },
      "776ad311-a90b-4e4f-af81-31fb6d4317e4/jipipe:adaptive-parameters/attach-parameter-annotations" : {
        "name" : "Attach parameter annotations",
        "description" : "If multiple parameters are allowed, attach the parameter values as annotations."
      },
      "2817e4fd-eafb-456f-9190-1876208d4b4c/jipipe:adaptive-parameters/enabled" : {
        "name" : "Enable adaptive parameters",
        "description" : "If enabled, you can use custom expressions to generate parameters. Please note that this will disable parallelization."
      },
      "9981ae91-45ca-4b9e-aaea-0d1609f59799/jipipe:parameter-slot-algorithm/attach-parameter-annotations" : {
        "name" : "Attach parameter annotations",
        "description" : "If multiple parameters are allowed, attach the parameter values as annotations."
      },
      "dde194a3-96af-46fd-b70f-5e0788555173/split-mode" : {
        "important" : true,
        "name" : "Split image",
        "description" : "Allows to split the image into 2D slices or 3D cubes before passing them to CLIJ. The results are automatically merged into an image with the same number of channels/frames/slices as the input image(s). Please note that if multiple input images are provided, the node will equalize the number of channels/frames/slices prior to the algorithm execution. If you split into 2D slices, channels/frames/slices will be equalized, while for 3D cubes channels and frames will be equalized. The equalization process will add new black cubes/slices if necessary (based on the maximum over all inputs), unless you set the equalization mode to 'Replicate'. Not applicable if 'Avoid allocating GPU memory' is disabled."
      },
      "e6eba9cb-edf6-4087-ae7b-79289ca4cf4a/merge-input-annotations" : {
        "name" : "Copy text annotations from input",
        "description" : "If enabled, annotations from the 'Input' slot are copied into the output (Default)."
      },
      "168b7e93-76a5-43f6-933a-d6d5a6c2e78f/gpu-parameters/gpu-device" : {
        "name" : "GPU device",
        "description" : "Which GPU device to use"
      },
      "a89f5cd6-5ac1-478c-b403-b9613633d950/annotation-type" : {
        "name" : "Removed annotations",
        "description" : "Annotations that match any of the filters are removed.\n\nThis parameter is an expression that has two modes: (1) Selecting an existing annotation by its name, and (2) Matching an existing annotation by boolean operators<br/><ol><li>Type in the name of the existing annotation. Put the name in double quotes (optional, but recommended). Example: <pre>\"#Dataset\"</pre></li><li>The function iterates through all annotations. It should return TRUE for one of them. You will have 'key' and 'value' available within the expression. Example: <pre>key == \"#Dataset\"</pre></li></ol>"
      },
      "5213d82a-b375-4af0-911e-763930121d4e/jipipe:node:ui-locked" : {
        "pinned" : true,
        "hidden" : true,
        "name" : "Lock location/size",
        "description" : "If enabled, lock the location and size of this node. Does not affect automated alignment operations. Will lock the size if the node supports a resize handle. Will prevent deletion of the node by the user. Slots can still be edited/connected and parameters can still be changed."
      },
      "168b7e93-76a5-43f6-933a-d6d5a6c2e78f/jipipe:adaptive-parameters/attach-only-non-default-parameter-annotations" : {
        "name" : "Attach only non-default parameter annotations",
        "description" : "If multiple parameters are allowed, attach only parameter annotations that have different values from the current settings. Requires 'Attach parameter annotations' to be enabled."
      },
      "d566983a-4d7e-4957-bda8-c11c6afe6a77/jipipe:adaptive-parameters/attach-only-non-default-parameter-annotations" : {
        "name" : "Attach only non-default parameter annotations",
        "description" : "If multiple parameters are allowed, attach only parameter annotations that have different values from the current settings. Requires 'Attach parameter annotations' to be enabled."
      },
      "fe98ec61-b3a6-43c3-92ea-fa7014754934/slice-threshold-mode" : {
        "name" : "Multi-slice thresholding",
        "description" : "Determines how thresholds are calculated if an image has multiple slices. <ul><li><b>Apply threshold per slice</b> calculates and applies the threshold for each slice.</li><li><b>Combine slice statistics</b> merges the slice histograms into one, which is then used for threshold calculation.</li><li><b>Combine thresholds per slice</b> calculates the threshold for each slice. One threshold for all slices is calculated via the math expression.</li></ul>"
      },
      "bf8aa75e-446a-4bfc-9433-e8b1e33d12b1/jipipe:adaptive-parameters/enabled" : {
        "name" : "Enable adaptive parameters",
        "description" : "If enabled, you can use custom expressions to generate parameters. Please note that this will disable parallelization."
