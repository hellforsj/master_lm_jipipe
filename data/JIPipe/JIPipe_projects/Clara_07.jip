          },
          "output" : {
            "Output" : {
              "slot-data-type" : "imagej-results-table",
              "slot-type" : "Output",
              "name" : "Output",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:ui-grid-location" : {
          "" : {
            "VerticalCompact" : {
              "x" : 35,
              "y" : 62
            }
          },
          "363fbc1c-56a0-4502-91e9-18c1fcc3a05d" : {
            "VerticalCompact" : {
              "x" : 38,
              "y" : 51
            }
          }
        },
        "jipipe:node-info-id" : "modify-tables",
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "# This script is executed for each table\n# Tables are passed as dictionary 'table'\n# Key are the column names\n# Values are string/double arrays\n# Annotations can be modified via a dict 'annotations'\n\nallHost = table[\"All macrophages\"]\nphagHost = table[\"Phagocytosing macrophages\"]\nphagPath = table[\"Phagocytosed spores\"]\nadhPath = table[\"Adherent spores\"]\nassocPath = table[\"Associated spores\"]\nfreePath = table[\"All free spores\"]\n\ntable[\"Uptake Ratio\"] = [float(phagHost[row]) / max(float(allHost[row]), 1.0) for row in range(len(allHost))]\ntable[\"Phagocytosis Ratio\"] = [float(phagPath[row]) / max(float(assocPath[row]), 1.0) for row in range(len(assocPath))]\ntable[\"Symmetrized Phagocytic Index\"] = [float(phagPath[row]) / max(float(assocPath[row]), 1.0) * (float(phagHost[row]) / max(float(allHost[row]),1.0)) for row in range(len(assocPath))]\ntable[\"Phagocytic Index\"] = [float(phagPath[row]) / max(float(phagHost[row]), 1.0) * float(phagHost[row]) / max(float(allHost[row]), 1.0) for row in range(len(assocPath))]\ntable[\"All spores\"] = [float(freePath[row]) + float(assocPath[row])] \n",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
        "jipipe:node:name" : "Modify tables (Script)",
