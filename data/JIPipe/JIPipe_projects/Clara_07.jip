      "b5115aea-b37c-46bf-b613-f627f81c56de/jipipe:adaptive-parameters/overridden-parameters" : {
        "important" : true,
        "name" : "Overridden parameters",
        "description" : "Here you can override the value of parameters based on annotations. The 'Value' settings should return a value for the parameter type or a JSON string that can be converted into a valid parameter value. The 'Parameter key' setting determines to which parameter this value is written to."
