      "3caa2c67-6820-44bc-8086-5a678eb64c7a/suppress-logs" : {
        "name" : "Suppress logs",
        "description" : "If enabled, the node will not log the status of the Cellpose operation. Can be used to limit memory consumption of JIPipe if larger data sets are used."
