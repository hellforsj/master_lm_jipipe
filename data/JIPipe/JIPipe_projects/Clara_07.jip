      "56b95f06-1710-413d-b866-1fa1711aebcb" : {
        "jipipe:graph-compartment" : "363fbc1c-56a0-4502-91e9-18c1fcc3a05d",
        "jipipe:alias-id" : "modify-tables-script",
        "jipipe:slot-configuration" : {
          "input" : {
            "Input" : {
              "slot-data-type" : "imagej-results-table",
              "slot-type" : "Input",
              "name" : "Input",
              "custom-name" : null,
              "description" : "",
