        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "from jipipe.imagej import *\nfrom scipy.spatial import KDTree\nimport pandas as pd\n\n\n# Get the input slot\nds = jipipe_inputs[\"Input\"]\n\n# Get the first table from the slot\ntable = load_table_file(data_slot=ds, row=0)\nCenterX = table[\"CenterX\"]\nCenterY = table[\"CenterY\"]\nCenterZ = table[\"CenterZ\"]\nprint(len(CenterX))\n\n# Create a DataFrame\ndata = {\n    'Column1': CenterX,\n    'Column2': CenterY,\n    'Column3': CenterZ\n}\n\ndf = pd.DataFrame(data)\nkdtree=KDTree(df)\ndist,points=kdtree.query(df,2)\ndistance = dist[:, 1]\nprint(\"****************************************\")\nprint(\"Distance vector length: \", len(dist))\nprint(\"****************************************\")\nprint(distance)\nprint(\"****************************************\")\ntable[\"Dist\"] = distance \n\n#table[\"Dist\"] = [float(CenterX[row]) + float(CenterY[row]) + float(CenterZ[row]) for row in range(len(CenterX))]\n\n# Get the output slot\ndso = jipipe_outputs[\"Output\"]\ndso1 = jipipe_outputs[\"Output 1\"]\n\n# Add the table to the output slot\nadd_table(table, dso)\nadd_table(distance, dso1)\n",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
