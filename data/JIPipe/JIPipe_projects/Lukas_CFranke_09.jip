      "d5d915ce-8aee-4d23-9fef-6a9b9715ac3e" : {
        "jipipe:graph-compartment" : "eb8f2fa4-c269-400a-97f3-8eceb0c20cb3",
        "jipipe:alias-id" : "python-script-iterating-neighbo",
        "jipipe:slot-configuration" : {
          "input" : {
            "Input" : {
              "slot-data-type" : "imagej-results-table",
              "slot-type" : "Input",
              "name" : "Input",
