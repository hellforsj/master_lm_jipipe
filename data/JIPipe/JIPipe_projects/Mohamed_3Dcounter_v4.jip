            }
          },
          "output" : {
            "Output" : {
              "slot-data-type" : "imagej-results-table",
              "slot-type" : "Output",
              "name" : "Output",
              "custom-name" : null,
              "description" : null,
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:ui-grid-location" : {
          "" : {
            "VerticalCompact" : {
              "x" : 53,
              "y" : 32
            }
          },
          "02241e71-6f7d-484c-adf7-040e57afa7ad" : {
            "VerticalCompact" : {
              "x" : 41,
              "y" : 48
            }
          }
        },
        "jipipe:node-info-id" : "modify-tables",
        "jipipe:algorithm:enabled" : true,
        "code" : {
          "code" : "# This script is executed for each table\n# Tables are passed as dictionary 'table'\n# Key are the column names\n# Values are string/double arrays\n# Annotations can be modified via a dict 'annotations'\n\nallHost = table[\"All macrophages\"]\nphagHost = table[\"Macrophages with phagocytosed bacteria\"]\nphagPath = table[\"Phagocytosed bacteria\"]\nadhPath = table[\"Adherent bacteria\"]\nassocPath = table[\"Associated bacteria\"]\n# assocPath = phagPath + adhPath\ntable[\"Uptake Ratio\"] = [float(phagHost[row]) / max(float(allHost[row]),1.0) for row in range(len(allHost))]\ntable[\"Phagocytosis Ratio\"] = [float(phagPath[row]) / max(float(assocPath[row]),1.0) for row in range(len(assocPath))]\ntable[\"Symmetrized Phagocytic Index\"] = [float(phagPath[row]) / max(float(assocPath[row]),1.0) * float(phagHost[row]) / max(float(allHost[row]),1.0) for row in range(len(assocPath))]\ntable[\"Phagocytic Index\"] = [float(phagPath[row]) / max(float(phagHost[row]),1.0) * float(phagHost[row]) / max(float(allHost[row]),1.0) for row in range(len(assocPath))]\n\n\n#test = [ x * x for x in allHost ]\n ",
          "collapsed" : false,
          "external-script-file" : {
            "content" : "",
            "enabled" : false
          }
        },
        "jipipe:parallelization:enabled" : true,
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
        "jipipe:node:name" : "Modify tables (Script)",
        "jipipe:node:description" : "<html><head></head><body></body></html>",
