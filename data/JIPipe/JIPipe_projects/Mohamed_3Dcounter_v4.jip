      "6dc397e7-5d3f-4e20-906b-bfaa63dd377e" : {
        "jipipe:graph-compartment" : "02241e71-6f7d-484c-adf7-040e57afa7ad",
        "jipipe:alias-id" : "modify-tables-script",
        "jipipe:slot-configuration" : {
          "input" : {
            "Input" : {
              "slot-data-type" : "imagej-results-table",
              "slot-type" : "Input",
              "name" : "Input",
