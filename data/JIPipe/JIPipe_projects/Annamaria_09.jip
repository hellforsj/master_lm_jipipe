    "docs" : {
      "a7237bd4-8935-4bca-a860-e4570dc6d44d/jipipe:algorithm:pass-through" : {
        "pinned" : true,
        "name" : "Pass through",
        "description" : "If enabled, the algorithm will pass the input data directly to the output data without any processing. This is different from enabling/disabling the algorithm as this will not disable dependent algorithms.\nPlease note that setting this parameter via adaptive parameters (if available) does not always yield the expected result. The reason behind this is that pass-through is not trivial for certain nodes. We recommend to use a split node if node execution should be made adaptive."
      },
      "981efe86-1d95-46da-b77e-f0bc8df5b387/jipipe:node:name" : {
        "pinned" : true,
        "name" : "Name",
        "description" : "Custom algorithm name."
      },
      "37b9fc4a-3c04-434f-b373-a1b3a0e1a9fd/jipipe:local-parallelization-num-threads" : {
        "pinned" : true,
        "name" : "Local parallelization",
        "description" : "If enabled, override the partition- and run-wide parallelization settings and apply parallelization only on this node."
      },
      "920f5f76-6bc5-4190-a754-29d451ccc2ea/jipipe:data-batch-generation/column-matching" : {
        "important" : true,
        "pinned" : true,
        "name" : "Grouping method",
        "description" : "Algorithms with multiple inputs require to match the incoming data to data sets. This allows you to determine how interesting data annotation columns are extracted from the incoming data. Union matches using the union of annotation columns. Intersection intersects the sets of available columns. You can also customize which columns should be included or excluded."
      },
      "1706b2fb-1ca9-4d63-b5ec-ef8562b82b6a/file-format" : {
        "name" : "File format",
        "description" : "The file format that should be used. <ul><li>PNG, JPEG, BMP: 2D images only</li><li>AVI: 2D or 3D images only</li><li>TIFF: All images supported</li></ul>"
      },
      "b5f6352e-2191-4906-a80f-4e6b40027d25/jipipe:adaptive-parameters/attach-only-non-default-parameter-annotations" : {
        "name" : "Attach only non-default parameter annotations",
        "description" : "If multiple parameters are allowed, attach only parameter annotations that have different values from the current settings. Requires 'Attach parameter annotations' to be enabled."
      },
      "0333971d-7f94-4a16-876e-2edc9bf92555/jipipe:algorithm:pass-through" : {
        "pinned" : true,
        "name" : "Pass through",
        "description" : "If enabled, the algorithm will pass the input data directly to the output data without any processing. This is different from enabling/disabling the algorithm as this will not disable dependent algorithms.\nPlease note that setting this parameter via adaptive parameters (if available) does not always yield the expected result. The reason behind this is that pass-through is not trivial for certain nodes. We recommend to use a split node if node execution should be made adaptive."
      },
      "0dcb7500-ba0e-4eca-9428-237901834ea6/jipipe:data-batch-generation/limit" : {
        "name" : "Limit",
        "description" : "Limits which iteration steps are generated. The first index is zero."
      },
      "88cf2fd2-a12f-4304-b24f-e77622e82d4a/jipipe:adaptive-parameters/attach-parameter-annotations" : {
