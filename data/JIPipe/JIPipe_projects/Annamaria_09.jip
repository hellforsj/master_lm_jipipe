        "code" : {
          "code" : "from jipipe.imagej import *\nfrom scipy.spatial import KDTree\nimport pandas as pd\nfrom sklearn.neighbors import NearestNeighbors\n\n\n# Get the input slot\nds = jipipe_inputs[\"Input\"]\nds1 = jipipe_inputs[\"Input 1\"]\n\n# Get the first table from the slot\ntable = load_table_file(data_slot=ds, row=0)\nCenterX = table[\"MassCenterX\"]\nCenterY = table[\"MassCenterY\"]\nCenterZ = table[\"MassCenterZ\"]\n\n# Get the first table from the slot\ntable1 = load_table_file(data_slot=ds1, row=0)\nCenterX1 = table1[\"MassCenterX\"]\nCenterY1 = table1[\"MassCenterY\"]\nCenterZ1 = table1[\"MassCenterZ\"]\n\n# Create a DataFrame\ndata = {\n    'Column1': CenterX,\n    'Column2': CenterY,\n    'Column3': CenterZ\n}\n\ndata1 = {\n    'Column1': CenterX1,\n    'Column2': CenterY1,\n    'Column3': CenterZ1\n}\n\ndf = pd.DataFrame(data)\ndf1 = pd.DataFrame(data1)\nkdtree=KDTree(df)\nkdtree1=KDTree(df1)\ndist,points=kdtree.query(df1,2)\ndistance = dist\n#distance = dist[:, 1]\n\n#neigh = NearestNeighbors(n_neighbors=1)\n#neigh.fit(df)\n#distance, indices = neigh.kneighbors(df1)\n#dist = distance\n\n\nprint(\"****************************************\")\nprint(\"Distance vector length: \", len(dist))\nprint(\"****************************************\")\nprint(distance)\nprint(\"****************************************\")\n#table[\"Dist\"] = distance[:,1] \n\n\n# Get the output slot\ndso = jipipe_outputs[\"Distances\"]\n\n# Add the table to the output slot\nadd_table(distance[:,0], dso)\n",
