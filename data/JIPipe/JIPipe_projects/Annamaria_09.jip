      },
      "eeacc4d5-7635-4651-b01c-2294f8d402d6/force-name" : {
        "name" : "Force name",
        "description" : "If enabled, the last component of the file path is used as name. Files will be written into the parent directory. If disabled, the file path is used as directory."
